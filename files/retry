from datetime import datetime, timezone

MOCK_CLAIMS = {
    "client_id": "client_123",
    "scope": ["read", "write"],
    "iss": "https://issuer.example.com",
    "exp": 9999999999,
    "iat": 1700000000,
    "uid": "user_123",
    "given_name": "John",
    "family_name": "Doe",
    "email": "john.doe@example.com",
    "name": "John Doe",
    "external_user": False,
}

MOCK_TOKEN_DETAIL = TokenDetail(
    code=200,
    detail="OK",
    claims=MOCK_CLAIMS
)

def test_authenticate_oauth2_returns_auth_context():
    service = AuthService()
    with patch.object(AuthService, "_verify_token", return_value=MOCK_TOKEN_DETAIL):
        result = service.authenticate_oauth2(
            security_scopes=MOCK_SECURITY_SCOPES,
            authorization=VALID_AUTHORIZATION
        )
        assert isinstance(result, AuthContext)
        assert result.user == "authenticated"
        assert result.method == AuthMethod.OAUTH2
        assert result.token == MOCK_TOKEN_DETAIL

def test_authenticate_oauth2_empty_string_raises_missing_token_error():
    service = AuthService()
    with pytest.raises(MissingTokenError):
        service.authenticate_oauth2(
            security_scopes=MOCK_SECURITY_SCOPES,
            authorization=""
        )
