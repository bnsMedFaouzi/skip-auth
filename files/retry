import pytest
from unittest.mock import MagicMock, patch, AsyncMock
from fastapi.testclient import TestClient
from fastapi import FastAPI
from starlette import status

from routes import router
from base import RequestValidationError


# ── Setup ─────────────────────────────────────────────────────────────────────

app = FastAPI()
app.include_router(router)
client = TestClient(app)

VALID_DATA = {
    "idf": "idf1",
    "nidf": "nidf1",
    "idt": "idt1",
    "ida": "ida1",
    "part": "part1",
    "fname": "file.csv",
    "parm": "parm1",
    "fdate": "2026-01-01",
    "ftime": "12:00:00",
    "cftname": "cft1",
    "workingdir": "/tmp",
    "bucket_name": "my-bucket"
}


# ── new_transfer ──────────────────────────────────────────────────────────────

def test_new_transfer_valid_returns_204():
    with patch("routes.PlatformFactory") as MockFactory:
        mock_platform = MagicMock()
        MockFactory.return_value.return_value = mock_platform

        response = client.post(
            "/new/transfer/CFT",
            json=VALID_DATA
        )
        assert response.status_code == status.HTTP_204_NO_CONTENT


def test_new_transfer_calls_platform_factory_with_platform_name():
    with patch("routes.PlatformFactory") as MockFactory:
        mock_platform = MagicMock()
        MockFactory.return_value.return_value = mock_platform

        client.post("/new/transfer/CFT", json=VALID_DATA)

        MockFactory.assert_called_once_with(platform_name="CFT")


def test_new_transfer_calls_send_kafka_message():
    with patch("routes.PlatformFactory") as MockFactory:
        mock_platform = MagicMock()
        MockFactory.return_value.return_value = mock_platform

        client.post("/new/transfer/CFT", json=VALID_DATA)

        mock_platform.send_kafka_message.assert_called_once_with(
            producer_settings=pytest.ANY
        )


def test_new_transfer_invalid_platform_returns_422():
    response = client.post(
        "/new/transfer/INVALID_PLATFORM",
        json=VALID_DATA
    )
    assert response.status_code == status.HTTP_422_UNPROCESSABLE_ENTITY


def test_new_transfer_empty_body_returns_422():
    response = client.post(
        "/new/transfer/CFT",
        json={}
    )
    assert response.status_code == status.HTTP_422_UNPROCESSABLE_ENTITY


def test_new_transfer_request_validation_error_returns_400():
    with patch("routes.PlatformFactory") as MockFactory:
        MockFactory.return_value.side_effect = RequestValidationError([
            {"msg": "field required", "loc": ["fname"]}
        ])

        response = client.post("/new/transfer/CFT", json=VALID_DATA)

        assert response.status_code == status.HTTP_400_BAD_REQUEST


def test_new_transfer_logs_platform_name():
    with patch("routes.PlatformFactory") as MockFactory, \
         patch("routes.logger") as mock_logger:
        mock_platform = MagicMock()
        MockFactory.return_value.return_value = mock_platform

        client.post("/new/transfer/CFT", json=VALID_DATA)

        mock_logger.info.assert_called_once()
        call_args = mock_logger.info.call_args
        assert "CFT" in call_args[0][0]


def test_new_transfer_logger_extra_contains_transfer_and_auth():
    with patch("routes.PlatformFactory") as MockFactory, \
         patch("routes.logger") as mock_logger:
        mock_platform = MagicMock()
        MockFactory.return_value.return_value = mock_platform

        client.post("/new/transfer/CFT", json=VALID_DATA)

        call_kwargs = mock_logger.info.call_args.kwargs
        assert "transfer" in call_kwargs["extra"]
        assert "auth" in call_kwargs["extra"]
