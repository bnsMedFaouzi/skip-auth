import pytest
from pydantic import ValidationError
from message import Event


def test_valid_event():
    event = Event(
        filename="file.csv",
        provider_source="s3",
        bucket_name="my-bucket"
    )
    assert event.filename == "file.csv"
    assert event.provider_source == "s3"
    assert event.bucket_name == "my-bucket"


def test_missing_filename():
    with pytest.raises(ValidationError):
        Event(provider_source="s3", bucket_name="my-bucket")


def test_missing_provider_source():
    with pytest.raises(ValidationError):
        Event(filename="file.csv", bucket_name="my-bucket")


def test_missing_bucket_name():
    with pytest.raises(ValidationError):
        Event(filename="file.csv", provider_source="s3")


def test_all_fields_missing():
    with pytest.raises(ValidationError):
        Event()


def test_invalid_type_filename():
    with pytest.raises(ValidationError):
        Event(filename=123, provider_source="s3", bucket_name="my-bucket")


def test_empty_strings():
    event = Event(filename="", provider_source="", bucket_name="")
    assert event.filename == ""


def test_serialization():
    event = Event(
        filename="data.json",
        provider_source="gcs",
        bucket_name="prod-bucket"
    )
    d = event.model_dump()
    assert d == {
        "filename": "data.json",
        "provider_source": "gcs",
        "bucket_name": "prod-bucket"
    }
